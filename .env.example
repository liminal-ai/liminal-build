# Template only. Copy these values into a local, ignored `.env.local` file.
PORT=5001
APP_ORIGIN=http://localhost:5001
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:5001/auth/callback
WORKOS_LOGIN_RETURN_URI=http://localhost:5001/projects
CONVEX_DEPLOYMENT=
CONVEX_URL=
# Convex deploy key (admin auth) — required so the server can call internal
# Convex functions such as the artifact persistence internalAction.
# Use the Convex dashboard ("Generate a deploy key") to mint one per environment.
CONVEX_DEPLOY_KEY=
