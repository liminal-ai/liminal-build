# Template only. Copy these values into a local, ignored `.env.local` file.
PORT=5001
APP_ORIGIN=http://localhost:5001
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:5001/auth/callback
WORKOS_LOGIN_RETURN_URI=http://localhost:5001/projects
CONVEX_DEPLOYMENT=
CONVEX_URL=
# Shared API key used by the Fastify control plane when calling the
# service-only Convex artifact wrappers. Set the same value in this file and in
# the active Convex deployment env as `CONVEX_API_KEY`.
CONVEX_API_KEY=
DAYTONA_API_KEY=
# Optional override; defaults to https://app.daytona.io/api when omitted.
DAYTONA_API_URL=
# Optional Daytona target/region (for example `us`).
DAYTONA_TARGET=
# GitHub Personal Access Token used by the code checkpoint writer to push
# durable code work back to canonical writable source target refs.
# Required scopes: `repo` (classic) OR fine-grained: contents:write +
# metadata:read on the target repos. Create at https://github.com/settings/tokens.
GITHUB_TOKEN=
